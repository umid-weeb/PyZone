{
"$schema": "https://openapi.vercel.sh/vercel.json",

"redirects": [
{
"source": "/arena",
"destination": "/zone",
"permanent": true
},
{
"source": "/arena.html",
"destination": "/zone",
"permanent": true
},
{
"source": "/zone/",
"destination": "/zone",
"permanent": true
}
],

"rewrites": [
{
"source": "/zone",
"destination": "/index.html"
},
{
"source": "/zone/(.*)",
"destination": "/index.html"
}
]
}
